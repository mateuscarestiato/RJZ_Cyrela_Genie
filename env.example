# Databricks workspace URL
DATABRICKS_HOST=https://adb-xxxx.azuredatabricks.net

# OAuth bearer token or PAT
DATABRICKS_TOKEN=dapi_seu_token_aqui

# Genie Space ID (UUID)
GENIE_SPACE_ID=xxxx-xxxx-xxxx-xxxx

# Optional tuning
GENIE_POLL_SECONDS=2
GENIE_TIMEOUT_SECONDS=600

# Supabase (Banco de Dados Cloud)
SUPABASE_URL="https://sua-url.supabase.co"
SUPABASE_KEY="sua_anon_key_aqui"

# Chave de Criptografia (Fernet) para tokens
ENCRYPTION_KEY="sua_fernet_key_gerada_aqui"

# Microsoft Entra ID (Azure AD) - SSO Corporativo
MS_CLIENT_ID="seu_client_id_aqui"
MS_CLIENT_SECRET="seu_client_secret_aqui"
MS_TENANT_ID="seu_tenant_id_aqui"
MS_REDIRECT_URI="http://localhost:8000/api/auth/microsoft/callback"
FRONTEND_URL="http://localhost:5173"
